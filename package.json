{
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:web": "cd web && npm ci && npm run build",
    "build:server": "rimraf dist && tsc && copyfiles -u 1 \"src/assets/**/*\" dist",
    "test": "jest",
    "start": "node dist/index.js",
    "deploy": "scripts/deploy.sh",
    "dev:server": "PORT=3007 NODE_ENV=development tsx watch src/index.ts",
    "dev:web": "cd web && npm run dev",
    "dev": "concurrently npm:dev:web npm:dev:server",
    "local-container": "docker build -t local-project-image . && docker run --rm -p 8080:8080 --env-file .env local-project-image"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-flow": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.0",
    "@types/node-fetch": "^2.6.13",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.13.1",
    "@durable-streams/client": "^0.2.1",
    "@durable-streams/server": "^0.2.1",
    "@google/genai": "^1.22.0",
    "commander": "^14.0.3",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@types/jsdom": "^27.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "diff": "^8.0.2",
    "e2b": "^2.12.0",
    "express": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "graphology": "^0.26.0",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "isbinaryfile": "^5.0.6",
    "jsdom": "^28.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.28.0",
    "ts-node": "^10.9.2"
  }
}
